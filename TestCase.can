  includes
{
  
}
variables
{
  const int wait_timeout=300;
  long waitresult;
  int window_up;
  
}
void maintest()
{
  testModuleTitle("LCM test");
  testModuleDescription("test cases written in capl");
  testReportAddEngineerInfo("DPIT","vector");
  testReportAddEngineerInfo("NAME","rupa mothuku");
  testReportAddEngineerInfo("version","17");
  testWaitForTimeout(200);
  testGroupBegin("simulation of signals","Test node communication");
  tc_ignition();
  test_exterior_light();
  TestWaitForTimeout(wait_timeout); 
  TC_washer_wiper();
  power_window_test();
  ts_mirror_contorls(); 
  ignitionoff();
  testGroupEnd();
}

testcase   tc_ignition()

{
  dword index=0;
  float ingition;
  float head_li;
  testCaseTitle("key position test","ignition");
  
  testStep("test step1","setsysvar=0");
  sysSetVariableInt(sysvar::Ignition_sysvar::Ignition_sysvar,0);
  waitresult=testWaitForSysVar(sysvar::Ignition_sysvar::Ignition_sysvar,wait_timeout);
  testJoinSysVarEvent(sysvar::Ignition_sysvar::Ignition_sysvar);

  index=testWaitForAnyJoinedEvent(250);
  switch(waitresult)
  {
    case 0: testStepFail("test step1","sysvar is not recieved");
      break;
      case 1: testGetWaitEventEnvVarData(index,ingition);
        if(!ingition)
       
          testStepPass("Test Step1","Switch is working fine");
        else
         testStepFail("Test Step 1","Switch is not working");
       
  }
  testWaitForTimeout(wait_timeout);
  
testStep("test step2","setsysvar=1");
  sysSetVariableInt(sysvar::Ignition_sysvar::Ignition_sysvar,1);

  waitresult=testWaitForSysVar(sysvar::Ignition_sysvar::Ignition_sysvar,wait_timeout);
  testJoinSysVarEvent(sysvar::Ignition_sysvar::Ignition_sysvar);

  index=testWaitForAnyJoinedEvent(250);
  switch(waitresult)
  {
    case 0: testStepFail("test step2","sysvar is not recieved");
      break;
      case 1: testGetWaitEventEnvVarData(index,ingition);
        if(@Ignition_sysvar::Ignition_sysvar==1)
       
          testStepPass("Test Step2","Switch is working fine");
        else
         testStepFail("Test Step 2","Switch is not working");
      
  }
  testWaitForTimeout(wait_timeout);
}

testcase test_exterior_light()
{
  dword index=0;
  float head_light;
  float drl_light;
  float direction_light;
  float hazard_light;
  
   testCaseTitle("head light position test","head light");
  
  testStep("test step1","setsysvar=1");
