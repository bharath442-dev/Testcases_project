  {
    case 0: testStepFail("test step3","sysvar is not recieved");
      break;
      case 1: testGetWaitEventEnvVarData(index,head_light);
        
        {
        if(@head_Light::head_Light==3)
       
          testStepPass("Test Step3","Switch is working fine");
        else
         testStepFail("Test Step3","Switch is not working");
        }
  }
  testWaitForTimeout(wait_timeout);
  
   testStep("test step4","setsysvar=4");
  sysSetVariableInt(sysvar::Direction_sysvar::Direction_sysvar,1);
  waitresult=testWaitForSysVar(sysvar::Direction_sysvar::Direction_sysvar,wait_timeout);
  testJoinSysVarEvent(sysvar::Direction_sysvar::Direction_sysvar);

  index=testWaitForAnyJoinedEvent(250);
  
  switch(waitresult)
  {
    case 0: testStepFail("test step4","sysvar is not recieved");
      break;
      case 1: testGetWaitEventEnvVarData(index, direction_light);
        
        {
        if(@Direction_sysvar::Direction_sysvar==1)
       
          testStepPass("Test Step4","Switch is working fine");
        else
         testStepFail("Test Step 4","Switch is not working");
        }
  }
  testWaitForTimeout(wait_timeout);
  
   testStep("test step5","setsysvar=5");
  sysSetVariableInt(sysvar::Direction_sysvar::Direction_sysvar,2);
  waitresult=testWaitForSysVar(sysvar::Direction_sysvar::Direction_sysvar,wait_timeout);
  testJoinSysVarEvent(sysvar::Direction_sysvar::Direction_sysvar);

  index=testWaitForAnyJoinedEvent(250);
  
  switch(waitresult)
  {
    case 0: testStepFail("test step4","sysvar is not recieved");
      break;
      case 1:  testGetWaitEventSysVarData(index,direction_light);
     
        
        {
        if(@Direction_sysvar::Direction_sysvar==2)
       
          testStepPass("Test Step5","Switch is working fine");
        else
         testStepFail("Test Step 5","Switch is not working");
        }
  }
  testWaitForTimeout(wait_timeout);
  
  
   testStep("test step6","setsysvar=6");
  sysSetVariableInt(sysvar::Hazard_sysvar::Hazard_sysvar,1);
  waitresult=testWaitForSysVar(sysvar::Hazard_sysvar::Hazard_sysvar,wait_timeout);
  testJoinSysVarEvent(sysvar::Hazard_sysvar::Hazard_sysvar);

  index=testWaitForAnyJoinedEvent(250);
  
  switch(waitresult)
  {
