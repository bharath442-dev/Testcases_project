  testStep("test step3","setsysvar=3");
  //sysSetVariableInt(sysvar::Ignition_sysvar::Ignition_sysvar,1);
  sysSetVariableInt(sysvar::head_Light::head_Light,3);
  waitresult=testWaitForSysVar(sysvar::head_Light::head_Light,wait_timeout);
  testJoinSysVarEvent(sysvar::head_Light::head_Light);

  index=testWaitForAnyJoinedEvent(250);
  
